  var Node2 = require_Node();
  function collectionFromPath(schema, path, value3) {
    let v = value3;
    for (let i = path.length - 1;i >= 0; --i) {
      const k = path[i];
      if (typeof k === "number" && Number.isInteger(k) && k >= 0) {
        const a = [];
