          tokens.push(previous);
        } else
          tokens.push({
            type: "Repetition",
            expression: previous,
            quantifier: {
              type: "Quantifier",
              kind: firstInBlock,
              greedy: true
            }
          });
        break;
      }
      case "{": {
        if (block === "{") {
          tokens.push(simpleChar(block));
          break;
