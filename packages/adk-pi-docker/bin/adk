function safeDecodeURI(path) {
  let shouldDecode = false;
  let shouldDecodeParam = false;
  let querystring = "";
  for (let i = 1;i < path.length; i++) {
    const charCode = path.charCodeAt(i);
    if (charCode === 37) {
