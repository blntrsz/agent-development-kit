var VALID_OPEN_API_COMPONENTS_SCHEMAS_KEY_REGEXP = /^[a-zA-Z0-9.\-_]+$/;
function sanitizeOpenApiComponentsSchemasKey(s) {
  if (s.length === 0)
    return "_";
